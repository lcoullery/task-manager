# Task Manager v2.0 Configuration
# Copy this file to .env and adjust as needed

# Server
NODE_ENV=production
PORT=4173
HOST=0.0.0.0

# JWT Secret - KEEP THIS SECRET! Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_SECRET

# JWT Token Expiration
JWT_ACCESS_TOKEN_EXPIRY=1h
JWT_REFRESH_TOKEN_EXPIRY=7d

# SQLite database path
DATABASE_PATH=./data/taskmanager.db

# CORS
CORS_ORIGIN=*

# Email (optional - invite URLs shown to admin if not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
APP_NAME=Task Manager
APP_URL=https://your-domain.com
